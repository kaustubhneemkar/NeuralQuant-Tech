# Alpha-Lens Environment Configuration
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
#
# Multiple keys enable automatic failover when one hits quota limits.
# At minimum, GOOGLE_API_KEY is required. Additional keys are optional.

GOOGLE_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY_2=your_second_key_here
GOOGLE_API_KEY_3=your_third_key_here
GOOGLE_API_KEY_4=your_fourth_key_here
